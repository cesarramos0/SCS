{
  "version": 2,
  "builds": [
    {
      "src": "scs-backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "scs-frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "scs-backend/main.py" },
    { "src": "/docs(.*)", "dest": "scs-backend/main.py" },
    { "src": "/redoc(.*)", "dest": "scs-backend/main.py" },
    { "src": "/openapi.json", "dest": "scs-backend/main.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}